<script>
  // Handle auth state in header
  document.addEventListener('DOMContentLoaded', () => {
    const token = localStorage.getItem('fl_token');
    if (token) {
      const authArea = document.getElementById('navAuthArea');
      if (authArea) {
        authArea.innerHTML = `
          <a href="/dashboard.html" class="signin" style="color: #2563EB; font-weight: 600;">Dashboard</a>
          <a href="#" onclick="localStorage.removeItem('fl_token'); window.location.href='/login.html'; return false;" class="signin" style="margin-left: 15px; color: #6B7280;">Sign out</a>
        `;
      }
    }
  });
</script>